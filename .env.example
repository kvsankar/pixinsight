# Copy this file to .env and adjust paths for your machine.
# .env is ignored by git.

# Optional. Defaults to projects/m31-andromeda-2013 under this repo.
PI_PROJECT_DIR=

# Optional local archive roots for inventory/search only. Keep actual values in .env or
# another ignored local file, never in committed docs.
PI_ARCHIVE_ROOT=
PI_BY_DATE_DIR=
PI_FINISHED_WORK_DIR=
PI_DARK_LIBRARY_DIR=
PI_FLAT_LIBRARY_DIR=

# Required for WBPP Phase 1 unless passed as -LightDir/-DarkDir.
PI_LIGHT_DIR=
# Optional alternative for targets split across folders. Semicolon-separated.
PI_LIGHT_DIRS=
PI_DARK_DIR=
# Optional alternative for darks split across folders. Semicolon-separated.
PI_DARK_DIRS=
# Optional calibration frames for WBPP Phase 1.
PI_FLAT_DIR=
PI_FLAT_DIRS=
PI_BIAS_DIR=
PI_BIAS_DIRS=
# Optional. Set true only for documented control runs when matching darks are unavailable.
PI_ALLOW_NO_DARKS=false
# Optional named WBPP output under projects/<slug>/work/.
PI_WBPP_OUTPUT_SUBDIR=wbpp-out
# Optional WBPP CFA override for dataset-specific diagnostics: AUTO, RGGB, BGGR, GBRG, or GRBG.
PI_CFA_PATTERN=

# Optional target-specific plate-solve seed. Defaults in the solver script are M31-oriented.
PI_SOLVE_RA=
PI_SOLVE_DEC=
PI_SOLVE_FOCAL_MM=
PI_SOLVE_PIXEL_UM=
PI_SOLVE_TARGET_MAX=
PI_SOLVE_MAX_BOX=
PI_SOLVE_MAGNITUDE=

# Optional SPCC sensor/filter response names. Example for Canon EOS 60D:
# PI_SPCC_RED_FILTER=Canon EOS 60D R
# PI_SPCC_GREEN_FILTER=Canon EOS 60D G
# PI_SPCC_BLUE_FILTER=Canon EOS 60D B
PI_SPCC_RED_FILTER=
PI_SPCC_GREEN_FILTER=
PI_SPCC_BLUE_FILTER=

# Optional named Phase 2 output under projects/<slug>/work/.
PI_PHASE2_OUTPUT_SUBDIR=02-linear

# Optional if PixInsight is installed in the default location known to the scripts.
# Otherwise set local install paths in .env, not in committed docs.
PIXINSIGHT_EXE=
PI_WBPP_SCRIPT=

# Optional local catalog path. Keep machine-specific catalog paths out of git.
PI_GAIA_DR3SP_DIR=
